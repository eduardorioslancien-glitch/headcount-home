function procesarArchivo(file) {
  const ext = file.name.split('.').pop().toLowerCase();
  if (ext === 'csv') {
    const reader = new FileReader();
    reader.onload = e => parsearCSV(e.target.result, file.name);
    reader.readAsText(file, 'UTF-8');
  } else if (ext === 'xlsx') {
    // Para xlsx usamos SheetJS si está disponible, sino pedimos CSV
    const reader = new FileReader();
    reader.onload = e => {
      try {
        // Intentar parsear como xlsx binario
        parsearXLSX(e.target.result, file.name);
      } catch(err) {
        showToast('⚠ Para archivos .xlsx guárdalos como .csv primero (Archivo → Guardar como → CSV)');
      }
    };
    reader.readAsArrayBuffer(file);
  } else {
    showToast('⚠ Solo se aceptan archivos .xlsx o .csv');
  }
}

function parsearCSV(text, filename) {
  const lines = text.split(/
?
/).filter(l => l.trim());
  if (lines.length < 2) { showToast('⚠ El archivo está vacío o solo tiene encabezados'); return; }
  const parseRow = line => {
    const result = []; let cur = ''; let inQ = false;
    for (let i = 0; i < line.length; i++) {
      if (line[i] === '"') { inQ = !inQ; }
      else if (line[i] === ',' && !inQ) { result.push(cur.trim()); cur = ''; }
      else { cur += line[i]; }
    }
    result.push(cur.trim());
    return result;
  };
  const headers = parseRow(lines[0]);
  const rows = lines.slice(1).map(l => parseRow(l)).filter(r => r.some(c => c));
  mostrarPreview(filename, headers, rows);
}

