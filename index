  const cont=document.getElementById('backlog-cards');
  if(!enProceso.length){ cont.innerHTML=`<div class="empty">Sin candidatos en proceso actualmente</div>`; }
  else {
    cont.innerHTML=enProceso.map(b=>{
      const desv=parseInt(b.desviacion)||0, dias=parseInt(b.dilacion)||0;
      const warn=desv>7?' ⚠':'';
      const estFalta=promDias>0?Math.max(0,promDias-dias)+'d est.':'–';
      return `<div class="cand-card">
        <div class="cand-top">
          <div class="avatar">${initials(b.completo)}</div>
          <div style="flex:1">
            <div class="cname">${b.completo} &nbsp;<span class="pill ${pillCls(b.status)}">${b.status}</span></div>
