<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>HEADCOUNT — HOME</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@2.44.0/tabler-icons.min.css">
<style>
:root{--verde:#0F6E56;--verde2:#1D9E75;--verde3:#5DCAA5;--verdeclaro:#EAF3DE;--azul:#185FA5;--azulclaro:#E6F1FB;--amber:#BA7517;--amberclaro:#FAEEDA;--rojo:#A32D2D;--rojoclaro:#FCEBEB;--morado:#534AB7;--moradoclaro:#EEEDFE;--gris0:#F7F6F2;--gris1:#EDEDEA;--gris2:#D3D1C7;--gris3:#888780;--gris4:#444441;--negro:#1A1A18;--blanco:#FFFFFF;--font:'DM Sans',sans-serif;--mono:'DM Mono',monospace;--radius:8px;--radius-lg:12px}
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:var(--font);background:var(--gris0);color:var(--negro);font-size:13px;line-height:1.5;height:100vh;overflow:hidden;display:flex}
.sidebar{width:200px;min-width:200px;background:var(--blanco);border-right:1px solid var(--gris1);display:flex;flex-direction:column;height:100vh}
.sidebar-logo{padding:16px;border-bottom:1px solid var(--gris1)}
.logo-hc{font-size:16px;font-weight:600;color:var(--negro)}
.logo-co{font-size:11px;font-weight:500;color:var(--verde);letter-spacing:0.5px;text-transform:uppercase;margin-top:1px}
.sec-lbl{padding:14px 12px 4px;font-size:9px;font-weight:600;color:var(--gris3);text-transform:uppercase;letter-spacing:1px}
.nav{display:flex;align-items:center;gap:8px;padding:7px 12px;font-size:12px;color:var(--gris4);cursor:pointer;border-radius:var(--radius);margin:1px 6px;transition:all .15s}
.nav:hover{background:var(--gris0);color:var(--negro)}
.nav.active{background:var(--verdeclaro);color:var(--verde);font-weight:500}
.nav i{font-size:15px;opacity:.6}.nav.active i{opacity:1;color:var(--verde)}
.nbadge{margin-left:auto;background:var(--rojoclaro);color:var(--rojo);font-size:9px;font-weight:600;padding:1px 6px;border-radius:20px}
.sb-footer{margin-top:auto;padding:12px 14px;border-top:1px solid var(--gris1);font-size:10px;color:var(--gris3)}
.main{flex:1;display:flex;flex-direction:column;overflow:hidden;min-width:0}
.topbar{height:52px;padding:0 20px;border-bottom:1px solid var(--gris1);display:flex;align-items:center;justify-content:space-between;background:var(--blanco);flex-shrink:0}
.topbar-left .title{font-size:15px;font-weight:600}
.topbar-left .sub{font-size:11px;color:var(--gris3);margin-top:1px}
.topbar-right{display:flex;gap:6px;align-items:center}
.btn{padding:6px 12px;font-size:11px;font-weight:500;border-radius:var(--radius);cursor:pointer;border:1px solid var(--gris2);background:var(--blanco);color:var(--gris4);font-family:var(--font);transition:all .15s}
.btn:hover{border-color:var(--gris3)}.btn-primary{background:var(--verde);color:var(--blanco);border-color:var(--verde)}.btn-primary:hover{background:#0a5540}
.btn-danger{background:var(--rojo);color:var(--blanco);border-color:var(--rojo)}.btn-sm{padding:4px 9px;font-size:11px}.btn-icon{padding:6px 8px}
.loading{display:flex;align-items:center;gap:6px;font-size:11px;color:var(--gris3)}
.dot-pulse{width:6px;height:6px;border-radius:50%;background:var(--verde3);animation:pulse 1.5s infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.3}}
.content{flex:1;overflow-y:auto;padding:16px 20px;background:var(--gris0)}
.screen{display:none}.screen.active{display:block}
/* KPI */
.kpi-grid{display:grid;grid-template-columns:repeat(8,1fr);gap:8px;margin-bottom:12px}
.kpi{background:var(--blanco);border-radius:var(--radius-lg);padding:12px 8px;display:flex;flex-direction:column;align-items:center;border:1px solid var(--gris1)}
.kpi-lbl{font-size:8px;font-weight:600;color:var(--gris3);text-transform:uppercase;letter-spacing:.4px;height:24px;display:flex;align-items:center;justify-content:center;text-align:center;line-height:1.2}
.kpi-val{font-size:22px;font-weight:600;color:var(--negro);font-family:var(--mono);margin-top:4px;line-height:1}
.kval-g{color:var(--verde)}.kval-a{color:var(--amber)}.kval-r{color:var(--rojo)}.kval-b{color:var(--azul)}
/* Chart */
.chart-card{background:var(--blanco);border-radius:var(--radius-lg);padding:14px 16px;margin-bottom:12px;border:1px solid var(--gris1)}
.chart-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:10px}
.chart-title{font-size:11px;font-weight:600}
.legends{display:flex;gap:12px}.leg{display:flex;align-items:center;gap:5px;font-size:10px;color:var(--gris3)}
.legline{width:16px;height:2.5px;border-radius:2px;display:inline-block}
/* Card/Table */
.card{background:var(--blanco);border-radius:var(--radius-lg);border:1px solid var(--gris1);overflow:hidden;margin-bottom:12px}
.card-header{padding:10px 14px;border-bottom:1px solid var(--gris1);display:flex;align-items:center;justify-content:space-between}
.card-title{font-size:11px;font-weight:600}
.tbl{width:100%;border-collapse:collapse;font-size:11px}
.tbl th{font-size:9px;font-weight:600;color:var(--gris3);text-align:left;padding:8px 12px;border-bottom:1px solid var(--gris1);background:var(--gris0);text-transform:uppercase;letter-spacing:.4px;white-space:nowrap}
.tbl td{padding:7px 12px;border-bottom:1px solid var(--gris1);color:var(--negro);vertical-align:middle}
.tbl tr:last-child td{border-bottom:none}.tbl tr:hover td{background:var(--gris0)}
.pill{display:inline-block;padding:2px 8px;border-radius:20px;font-size:9px;font-weight:600;white-space:nowrap}
.p-act{background:var(--verdeclaro);color:var(--verde)}.p-proc{background:var(--amberclaro);color:var(--amber)}
.p-ces{background:var(--rojoclaro);color:var(--rojo)}.p-adm{background:var(--azulclaro);color:var(--azul)}
.p-cert{background:var(--moradoclaro);color:var(--morado)}.p-ab{background:var(--amberclaro);color:var(--amber)}
/* Tabs */
.tabs{display:flex;border-bottom:1px solid var(--gris1);margin-bottom:12px}
.tab{padding:8px 14px;font-size:11px;font-weight:500;color:var(--gris3);cursor:pointer;border-bottom:2px solid transparent;margin-bottom:-1px;transition:all .15s}
.tab.on{color:var(--verde);border-bottom-color:var(--verde);font-weight:600}
/* Asistencia */
.ac{display:inline-flex;align-items:center;justify-content:center;width:28px;height:28px;border-radius:5px;font-size:11px;font-weight:700;cursor:pointer;font-family:var(--mono);transition:all .1s;user-select:none}
.aA{background:var(--verdeclaro);color:var(--verde)}.aF{background:var(--rojoclaro);color:var(--rojo)}
.aT{background:var(--amberclaro);color:var(--amber)}.aD{background:var(--gris1);color:var(--gris3)}
.a_{background:var(--gris0);color:var(--gris2);border:1px dashed var(--gris2)}
/* Form */
.form-card{background:var(--blanco);border:1px solid var(--gris1);border-radius:var(--radius-lg);padding:14px;margin-bottom:12px}
.fg{display:grid;grid-template-columns:repeat(3,1fr);gap:10px}
.fg2{display:grid;grid-template-columns:repeat(2,1fr);gap:10px}
.fg4{display:grid;grid-template-columns:repeat(4,1fr);gap:10px}
.ff label{font-size:9px;font-weight:600;color:var(--gris3);display:block;margin-bottom:4px;text-transform:uppercase;letter-spacing:.4px}
.ff select,.ff input,.ff textarea{width:100%;font-size:12px;padding:6px 9px;border-radius:var(--radius);border:1px solid var(--gris2);background:var(--blanco);font-family:var(--font);color:var(--negro);outline:none}
.ff select:focus,.ff input:focus,.ff textarea:focus{border-color:var(--verde);box-shadow:0 0 0 2px rgba(15,110,86,.1)}
.ff textarea{resize:vertical;min-height:60px}
.dinfo{font-size:9px;color:var(--gris3);margin-top:4px;line-height:1.5}
.form-actions{display:flex;gap:8px;justify-content:flex-end;margin-top:12px;padding-top:10px;border-top:1px solid var(--gris1)}
/* Backlog / Candidatos */
.cand-card{background:var(--blanco);border:1px solid var(--gris1);border-radius:var(--radius-lg);padding:12px 14px;margin-bottom:8px}
.cand-top{display:flex;align-items:center;gap:10px;margin-bottom:10px}
.avatar{width:36px;height:36px;min-width:36px;border-radius:50%;background:var(--verde);color:var(--blanco);display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:600}
.cname{font-size:12px;font-weight:600}.cmeta{font-size:10px;color:var(--gris3);margin-top:1px}
.htl{display:flex;align-items:flex-start}
.hito{display:flex;flex-direction:column;align-items:center;flex:1;position:relative}
.hito:not(:last-child)::after{content:'';position:absolute;top:10px;left:50%;width:100%;height:1.5px;background:var(--gris1);z-index:0}
.hito.done:not(:last-child)::after{background:var(--verde2)}
.hdot{width:20px;height:20px;border-radius:50%;border:2px solid var(--gris2);background:var(--blanco);display:flex;align-items:center;justify-content:center;font-size:9px;z-index:1;position:relative;font-weight:600}
.hito.done .hdot{background:var(--verde);border-color:var(--verde);color:var(--blanco)}
.hito.pend .hdot{background:var(--gris0);color:var(--gris3)}
.hn{font-size:8px;color:var(--gris3);margin-top:4px;text-align:center;line-height:1.2}
.hd{font-size:8px;color:var(--gris3);text-align:center;font-family:var(--mono)}
/* Config */
.ctabs{display:flex;gap:4px;margin-bottom:12px;flex-wrap:wrap}
.ctab{padding:5px 12px;font-size:11px;font-weight:500;border-radius:var(--radius);cursor:pointer;border:1px solid var(--gris2);background:var(--blanco);color:var(--gris4);font-family:var(--font);transition:all .15s}
.ctab.on{background:var(--verde);color:var(--blanco);border-color:var(--verde)}
.csec{display:none}.csec.on{display:block}
.cfg-row{display:flex;align-items:center;gap:10px;padding:8px 12px;border-bottom:1px solid var(--gris1);font-size:11px}
.cfg-lbl{flex:1;font-weight:500}.cfg-val{font-size:15px;font-weight:600;color:var(--verde);min-width:40px;font-family:var(--mono)}
.cfg-sub{font-size:10px;color:var(--gris3);flex:2}
.add-row{display:flex;gap:8px;margin-bottom:12px;align-items:flex-end;flex-wrap:wrap}
.add-row .ff{flex:1;min-width:100px}
/* Modal */
.modal-bg{display:none;position:fixed;inset:0;background:rgba(0,0,0,.4);z-index:100;align-items:center;justify-content:center}
.modal-bg.open{display:flex}
.modal{background:var(--blanco);border-radius:var(--radius-lg);width:780px;max-width:95vw;max-height:90vh;overflow-y:auto;box-shadow:0 20px 60px rgba(0,0,0,.2)}
.modal-header{padding:16px 20px;border-bottom:1px solid var(--gris1);display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;background:var(--blanco);z-index:1}
.modal-title{font-size:14px;font-weight:600}
.modal-body{padding:20px}
.modal-footer{padding:14px 20px;border-top:1px solid var(--gris1);display:flex;gap:8px;justify-content:flex-end;position:sticky;bottom:0;background:var(--blanco)}
/* Hint */
.hint{font-size:10px;color:var(--gris3);font-style:italic;margin-top:8px;padding:6px 10px;background:var(--gris0);border-radius:var(--radius);border-left:2px solid var(--gris2)}
.empty{text-align:center;padding:40px;color:var(--gris3);font-size:12px}
.spinner{display:inline-block;width:14px;height:14px;border:2px solid var(--gris2);border-top-color:var(--verde);border-radius:50%;animation:spin .8s linear infinite;margin-right:6px;vertical-align:middle}
@keyframes spin{to{transform:rotate(360deg)}}
.toast{position:fixed;bottom:20px;right:20px;background:var(--negro);color:var(--blanco);padding:10px 16px;border-radius:var(--radius-lg);font-size:12px;font-weight:500;z-index:999;opacity:0;transform:translateY(10px);transition:all .3s;pointer-events:none}
.toast.show{opacity:1;transform:translateY(0)}
/* Calculadora */
.calc-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px}
.calc-result{background:var(--verdeclaro);border-radius:var(--radius-lg);padding:14px;text-align:center}
.calc-result-lbl{font-size:10px;color:var(--verde);font-weight:600;text-transform:uppercase;letter-spacing:.5px}
.calc-result-val{font-size:28px;font-weight:700;color:var(--verde);font-family:var(--mono);margin-top:4px}
.calc-result-sub{font-size:10px;color:var(--verde);margin-top:2px}
/* Entrevista */
.comp-row{background:var(--gris0);border-radius:var(--radius);padding:10px 12px;margin-bottom:8px}
.comp-name{font-size:11px;font-weight:600;color:var(--negro);margin-bottom:4px}
.comp-preg{font-size:10px;color:var(--gris3);margin-bottom:6px;font-style:italic}
.star-row{display:flex;gap:4px;margin-bottom:4px}
.star{font-size:18px;cursor:pointer;color:var(--gris2);transition:color .1s}.star.on{color:#F5A623}
::-webkit-scrollbar{width:5px;height:5px}::-webkit-scrollbar-track{background:transparent}::-webkit-scrollbar-thumb{background:var(--gris2);border-radius:10px}
.rper-btn{border-color:var(--gris2);color:var(--gris4)}.active-per{background:var(--verde);color:#fff;border-color:var(--verde)}
.alerta-item{display:flex;align-items:flex-start;gap:10px;padding:8px 0;border-bottom:1px solid var(--gris1);font-size:11px}
.alerta-item:last-child{border-bottom:none}
.alerta-icon{font-size:16px;min-width:20px}
.alerta-body{flex:1}.alerta-title{font-weight:600;color:var(--negro)}.alerta-sub{color:var(--gris3);font-size:10px;margin-top:1px}
.alerta-badge{padding:2px 8px;border-radius:20px;font-size:9px;font-weight:600}
.ab-rojo{background:var(--rojoclaro);color:var(--rojo)}.ab-amber{background:var(--amberclaro);color:var(--amber)}.ab-verde{background:var(--verdeclaro);color:var(--verde)}
.etapa-bar{display:flex;align-items:center;gap:8px;padding:5px 0;font-size:11px}
.etapa-lbl{width:110px;font-weight:500;color:var(--negro)}
.etapa-track{flex:1;height:10px;background:var(--gris1);border-radius:10px;overflow:hidden}
.etapa-fill{height:100%;border-radius:10px;transition:width .4s}
.etapa-cnt{font-family:var(--mono);font-weight:600;color:var(--negro);min-width:24px;text-align:right}
.section-divider{font-size:11px;font-weight:600;color:var(--gris3);text-transform:uppercase;letter-spacing:.8px;margin:16px 0 8px;padding-bottom:4px;border-bottom:1px solid var(--gris1)}
</style>
</head>
<body>

<!-- SIDEBAR -->
<div class="sidebar">
  <div class="sidebar-logo">
    <div class="logo-hc">HEADCOUNT</div>
    <div class="logo-co">HOME</div>
  </div>
  <div class="sec-lbl">Principal</div>
  <div class="nav active" onclick="go('dashboard',this)"><i class="ti ti-layout-dashboard"></i> Dashboard</div>
  <div class="nav" onclick="go('cuadrillas',this)"><i class="ti ti-users"></i> Cuadrillas</div>
  <div class="nav" onclick="go('asistencia',this)"><i class="ti ti-calendar-check"></i> Asistencia</div>
  <div class="sec-lbl">Gestión</div>
  <div class="nav" onclick="go('requerimiento',this)"><i class="ti ti-file-plus"></i> Requerimientos</div>
  <div class="nav" onclick="go('candidatos',this)"><i class="ti ti-user-check"></i> Candidatos PT</div>
  <div class="nav" onclick="go('backlog',this)"><i class="ti ti-list-check"></i> Backlog <span class="nbadge" id="badge-backlog">–</span></div>
  <div class="nav" onclick="go('reportes',this)"><i class="ti ti-chart-bar"></i> Reportes</div>
  <div class="sec-lbl">Admin</div>
  <div class="nav" onclick="go('config',this)"><i class="ti ti-settings"></i> Configuración</div>
  <div class="sb-footer">Acceso exclusivo: HOME</div>
</div>

<!-- MAIN -->
<div class="main">
  <div class="topbar">
    <div class="topbar-left">
      <div class="title" id="scr-title">Dashboard</div>
      <div class="sub" id="scr-sub">Cargando...</div>
    </div>
    <div class="topbar-right">
      <div class="loading" id="loading-ind"><div class="dot-pulse"></div> Sincronizando</div>
      <button class="btn btn-icon" onclick="recargarTodo()" title="Actualizar"><i class="ti ti-refresh"></i></button>
      <button class="btn btn-primary" id="main-btn" onclick="mainAction()">+ Nuevo requerimiento</button>
    </div>
  </div>

  <div class="content">

    <!-- DASHBOARD -->
    <div class="screen active" id="s-dashboard">
      <div class="kpi-grid">
        <div class="kpi"><div class="kpi-lbl">HC Meta</div><div class="kpi-val" id="k-meta">–</div></div>
        <div class="kpi"><div class="kpi-lbl">HC Cubierto</div><div class="kpi-val kval-g" id="k-cub">–</div></div>
        <div class="kpi"><div class="kpi-lbl">Altas</div><div class="kpi-val kval-g" id="k-altas">–</div></div>
        <div class="kpi"><div class="kpi-lbl">Bajas</div><div class="kpi-val" id="k-bajas">–</div></div>
        <div class="kpi"><div class="kpi-lbl">Planing</div><div class="kpi-val kval-b" id="k-plan">–</div></div>
        <div class="kpi"><div class="kpi-lbl">HC Efectivo</div><div class="kpi-val kval-g" id="k-efec">–</div></div>
        <div class="kpi"><div class="kpi-lbl">A tiempo</div><div class="kpi-val kval-g" id="k-atie">–</div></div>
        <div class="kpi"><div class="kpi-lbl">Tarde</div><div class="kpi-val kval-a" id="k-tard">–</div></div>
      </div>
      <div class="chart-card">
        <div class="chart-head">
          <div class="chart-title">Semana actual — Meta · Cubierto · Efectivo</div>
          <div class="legends">
            <span class="leg"><span class="legline" style="background:#9FE1CB"></span> Meta</span>
            <span class="leg"><span class="legline" style="background:var(--verde)"></span> Cubierto</span>
            <span class="leg"><span class="legline" style="background:var(--azul)"></span> Efectivo</span>
          </div>
        </div>
        <svg id="linesvg" viewBox="0 0 520 110" xmlns="http://www.w3.org/2000/svg" style="width:100%;display:block"></svg>
      </div>
      <div class="card">
        <div class="card-header"><div class="card-title">Por operador y base — hoy</div></div>
        <table class="tbl"><thead><tr><th>Operador</th><th>Base</th><th>Meta</th><th>Cubierto</th><th>Altas</th><th>Bajas</th><th>Planing</th><th>Efectivo</th><th>A tiempo</th><th>Tarde</th></tr></thead>
        <tbody id="tbody-opbase"><tr><td colspan="10" class="empty"><span class="spinner"></span>Cargando...</td></tr></tbody></table>
      </div>
    </div>

    <!-- CUADRILLAS -->
    <div class="screen" id="s-cuadrillas">
      <div class="tabs">
        <div class="tab on" onclick="switchTab(this,'tact')">Activos (<span id="cnt-act">–</span>)</div>
        <div class="tab" onclick="switchTab(this,'tproc')">En proceso (<span id="cnt-proc">–</span>)</div>
        <div class="tab" onclick="switchTab(this,'tces')">Cesados (<span id="cnt-ces">–</span>)</div>
      </div>
      <div id="tact"><div class="card"><table class="tbl">
        <thead><tr><th>Nombre completo</th><th>DNI</th><th>Celular</th><th>Operador</th><th>Base</th><th>Tipo</th><th>Movilidad</th><th>F. Ingreso</th><th>Pedido</th><th></th></tr></thead>
        <tbody id="tbody-activos"><tr><td colspan="10" class="empty"><span class="spinner"></span>Cargando...</td></tr></tbody>
      </table></div></div>
      <div id="tproc" style="display:none"><div class="card"><table class="tbl">
        <thead><tr><th>Nombre completo</th><th>DNI</th><th>Celular</th><th>Operador</th><th>Base</th><th>Tipo</th><th>Pedido</th><th>Status</th><th></th></tr></thead>
        <tbody id="tbody-proceso"><tr><td colspan="9" class="empty"><span class="spinner"></span>Cargando...</td></tr></tbody>
      </table></div></div>
      <div id="tces" style="display:none"><div class="card"><table class="tbl">
        <thead><tr><th>Nombre completo</th><th>DNI</th><th>Operador</th><th>Base</th><th>F. Ingreso</th><th>F. Cese</th><th>Pedido</th><th></th></tr></thead>
        <tbody id="tbody-cesados"><tr><td colspan="8" class="empty">Sin registros de cesados.</td></tr></tbody>
      </table></div></div>
    </div>

    <!-- ASISTENCIA -->
    <div class="screen" id="s-asistencia">
      <div class="form-card" style="display:flex;align-items:center;gap:12px;flex-wrap:wrap">
        <div class="ff" style="flex:0 0 auto">
          <label>Fecha</label>
          <input type="date" id="asist-fecha" onchange="cargarAsistencia()">
        </div>
        <div style="flex:1;font-size:10px;color:var(--gris3);align-self:flex-end;padding-bottom:2px">
          Toca cada celda para cambiar: <strong>A</strong> Asiste · <strong>T</strong> Tardanza · <strong>F</strong> Falta · <strong>D</strong> Descanso · <strong>—</strong> Sin registro
        </div>
