}

function buildRepHCChart(cub, meta){
  const svg=document.getElementById('rep-svg-hc'); if(!svg) return;
  const W=320,H=100,PL=28,PR=10,PT=8,PB=20,cw=W-PL-PR,ch=H-PT-PB;
  // Simular semana con datos reales del día
  const days=['L','M','X','J','V','S','D'];
  const metaArr=Array(7).fill(meta);
  const cubArr=[Math.max(0,cub-4),Math.max(0,cub-3),Math.max(0,cub-2),Math.max(0,cub-1),cub,cub,cub];
  const maxY=Math.max(meta,cub)+2;
  const n=7;
  const px=i=>PL+(i/(n-1))*cw, py=v=>PT+ch-(v/maxY)*ch;
  const smooth=arr=>{ let d=`M${px(0)} ${py(arr[0])}`; for(let i=1;i<arr.length;i++){const cx=(px(i-1)+px(i))/2; d+=` C${cx} ${py(arr[i-1])} ${cx} ${py(arr[i])} ${px(i)} ${py(arr[i])}`} return d; };
  let out='';
  [0,Math.round(maxY/2),maxY].forEach(v=>{ out+=`<line x1="${PL}" y1="${py(v)}" x2="${W-PR}" y2="${py(v)}" stroke="#eee" stroke-width="0.5"/><text x="${PL-3}" y="${py(v)+3}" text-anchor="end" font-size="7" fill="#aaa">${v}</text>`; });
  days.forEach((d,i)=>{ out+=`<text x="${px(i)}" y="${H-4}" text-anchor="middle" font-size="8" fill="#aaa">${d}</text>`; });
  out+=`<line x1="${px(0)}" y1="${py(meta)}" x2="${px(n-1)}" y2="${py(meta)}" stroke="#9FE1CB" stroke-width="1.2" stroke-dasharray="4,3"/>`;
  out+=`<path d="${smooth(cubArr)}" fill="none" stroke="#0F6E56" stroke-width="2" stroke-linecap="round"/>`;
  cubArr.forEach((v,i)=>{ out+=`<circle cx="${px(i)}" cy="${py(v)}" r="3" fill="#0F6E56"/>`; });
  svg.innerHTML=out;
}

