async function ejecutarCarga() {
  if (!_cargaData || !_cargaData.rows.length) { showToast('⚠ No hay datos para cargar'); return; }
  const hoja = document.getElementById('carga-hoja').value;
  const modo = document.getElementById('carga-modo').value;
  const rows = _cargaData.rows;
  const BATCH = 50; // filas por lote
  const total = rows.length;
  let cargadas = 0; let errores = 0;

  document.getElementById('carga-preview').style.display = 'none';
  document.getElementById('carga-progress').style.display = 'block';
  document.getElementById('carga-log-card').style.display = 'none';

  const log = [];

  // Si modo replace, limpiar primero (enviar acción limpiar)
  if (modo === 'replace') {
    try {
      await wPost({accion:'limpiar_hoja', contrata:CONTRATA, hoja});
      log.push('🗑 Contenido anterior eliminado');
    } catch(e) {
      log.push('⚠ No se pudo limpiar: ' + e.message);
    }
  }

  // Cargar en lotes
  for (let i = 0; i < rows.length; i += BATCH) {
    const lote = rows.slice(i, i + BATCH);
    const pct = Math.round(((i + lote.length) / total) * 100);
    document.getElementById('carga-progress-lbl').textContent = `Cargando... ${i + lote.length} de ${total} filas (${pct}%)`;
    document.getElementById('carga-progress-bar').style.width = pct + '%';
    try {
      const res = await wPost({accion:'append', contrata:CONTRATA, hoja, rows:lote});
      if (res && res.ok) {
        cargadas += lote.length;
        log.push(`✅ Lote ${Math.floor(i/BATCH)+1}: ${lote.length} filas cargadas`);
      } else {
        errores += lote.length;
        log.push(`⚠ Lote ${Math.floor(i/BATCH)+1}: error — ${res?.error||'desconocido'}`);
      }
    } catch(e) {
      errores += lote.length;
      log.push(`❌ Lote ${Math.floor(i/BATCH)+1}: error de conexión — ${e.message}`);
    }
    // Pequeña pausa entre lotes para no saturar
    await new Promise(r => setTimeout(r, 300));
  }

  document.getElementById('carga-progress-lbl').textContent = `✅ Completado: ${cargadas} filas cargadas, ${errores} errores`;
  document.getElementById('carga-progress-bar').style.width = '100%';
  document.getElementById('carga-log-card').style.display = 'block';
  document.getElementById('carga-log').innerHTML = log.map(l=>`<div style="padding:3px 0;border-bottom:1px solid var(--gris1)">${l}</div>`).join('');

  if (cargadas > 0) {
    showToast(`✅ ${cargadas} filas cargadas en ${hoja}`);
    await recargarTodo();
  }
}


