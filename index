function getMeta(){
  if(!METAS_LOCAL.length) return 10;
  const t=today(); let m=10;
  METAS_LOCAL.sort((a,b)=>a.fecha.localeCompare(b.fecha)).forEach(x=>{ if(x.fecha<=t) m=parseInt(x.val)||m; });
  return m;
}

function buildChart(cubHoy,metaHoy,efecHoy){
  const svg=document.getElementById('linesvg'); if(!svg) return;
  const W=520,H=110,PL=30,PR=12,PT=10,PB=24,cw=W-PL-PR,ch=H-PT-PB;
  const days=['Lun','Mar','Mié','Jue','Vie','Sáb','Dom'],n=days.length;
  const meta=Array(7).fill(metaHoy);
  const cub=[Math.max(0,cubHoy-5),Math.max(0,cubHoy-3),Math.max(0,cubHoy-2),Math.max(0,cubHoy-1),cubHoy,cubHoy,cubHoy];
  const efec=[Math.max(0,efecHoy-2),Math.max(0,efecHoy-1),efecHoy,Math.max(0,efecHoy-1),efecHoy,efecHoy,efecHoy];
  const maxY=Math.max(...meta,...cub,...efec,10)+1;
  const px=i=>PL+(i/(n-1))*cw, py=v=>PT+ch-(v/maxY)*ch;
  const smooth=arr=>{ let d=`M${px(0)} ${py(arr[0])}`; for(let i=1;i<arr.length;i++){const x0=px(i-1),y0=py(arr[i-1]),x1=px(i),y1=py(arr[i]),cx=(x0+x1)/2; d+=` C${cx} ${y0} ${cx} ${y1} ${x1} ${y1}`} return d; };
  let out='';
  [0,Math.round(maxY/3),Math.round(maxY*2/3),maxY].forEach(v=>{ const y=py(v); out+=`<line x1="${PL}" y1="${y}" x2="${W-PR}" y2="${y}" stroke="#E8E8E4" stroke-width="0.5"/><text x="${PL-4}" y="${y+3.5}" text-anchor="end" font-size="8" fill="#aaa">${v}</text>`; });
  days.forEach((d,i)=>{ out+=`<text x="${px(i)}" y="${H-6}" text-anchor="middle" font-size="9" fill="#aaa">${d}</text>`; });
  out+=`<line x1="${px(0)}" y1="${py(metaHoy)}" x2="${px(n-1)}" y2="${py(metaHoy)}" stroke="#9FE1CB" stroke-width="1.5" stroke-dasharray="5,3"/>`;
  out+=`<polygon points="${cub.map((v,i)=>`${px(i)},${py(v)}`).join(' ')} ${px(n-1)},${py(0)} ${px(0)},${py(0)}" fill="rgba(15,110,86,.06)"/>`;
  out+=`<path d="${smooth(cub)}" fill="none" stroke="#0F6E56" stroke-width="1.5" stroke-linecap="round"/>`;
  out+=`<path d="${smooth(efec)}" fill="none" stroke="#185FA5" stroke-width="1.8" stroke-linecap="round"/>`;
  cub.forEach((v,i)=>{ out+=`<circle cx="${px(i)}" cy="${py(v)}" r="4" fill="#0F6E56"/><text x="${px(i)}" y="${py(v)-7}" text-anchor="middle" font-size="9" font-weight="600" fill="#0F6E56">${v}</text>`; });
  efec.forEach((v,i)=>{ out+=`<circle cx="${px(i)}" cy="${py(v)}" r="3" fill="#185FA5"/>`; });
  svg.innerHTML=out;
}

