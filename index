// ── ENTREVISTA: persistencia en sesión ──────────────────────
function setStar(compIdx, val){
  const numDoc = _candActual?.numDoc;
  if(!numDoc) return;
  if(!_entrevistas[numDoc]) _entrevistas[numDoc]={scores:{},notas:''};
  _entrevistas[numDoc].scores[compIdx] = val;
  const stars = document.getElementById('stars-'+compIdx)?.querySelectorAll('.star');
  if(stars) stars.forEach((s,i)=>s.classList.toggle('on', i<val));
  actualizarPromedio(numDoc);
}

function actualizarPromedio(numDoc){
  const ev = _entrevistas[numDoc];
  if(!ev||!Object.keys(ev.scores).length) return;
  const vals = Object.values(ev.scores);
  const prom = vals.reduce((a,b)=>a+b,0)/vals.length;
  const badge = document.getElementById('entrev-prom-badge');
  if(badge){
    badge.style.display='inline-block';
    badge.textContent='Promedio: '+prom.toFixed(1)+' ★';
    badge.style.background = prom>=4?'var(--verdeclaro)':prom>=3?'var(--amberclaro)':'var(--rojoclaro)';
    badge.style.color = prom>=4?'var(--verde)':prom>=3?'var(--amber)':'var(--rojo)';
  }
}

function guardarEntrevista(){
  const numDoc = _candActual?.numDoc; if(!numDoc) return;
  if(!_entrevistas[numDoc]) _entrevistas[numDoc]={scores:{},notas:''};
  const notas = document.getElementById('entrev-notas')?.value||'';
  _entrevistas[numDoc].notas = notas;
  // Leer scores actuales de estrellas
  COMPETENCIAS.forEach((c,i)=>{
    const stars = document.getElementById('stars-'+i)?.querySelectorAll('.star.on');
    if(stars) _entrevistas[numDoc].scores[i] = stars.length;
  });
  const hint = document.getElementById('entrev-guardada-hint');
  if(hint){ hint.style.display='block'; setTimeout(()=>hint.style.display='none',3000); }
  actualizarPromedio(numDoc);
  showToast('✅ Entrevista guardada');
}

function cargarEntrevistaGuardada(numDoc){
  const ev = _entrevistas[numDoc];
  if(!ev) return;
  // Restaurar estrellas
  COMPETENCIAS.forEach((c,i)=>{
    const val = ev.scores[i]||0;
    const stars = document.getElementById('stars-'+i)?.querySelectorAll('.star');
    if(stars) stars.forEach((s,idx)=>s.classList.toggle('on', idx<val));
  });
  // Restaurar notas
  const notasEl = document.getElementById('entrev-notas');
  if(notasEl) notasEl.value = ev.notas||'';
  actualizarPromedio(numDoc);
}

// ── CALCULADORA REAL CON PRECIARIO ──────────────────────────
function calcInicializar(){
  const ops=[...new Set(PRECIARIO_DATA.map(p=>p.op))];
  const selOp=document.getElementById('calc-op');
  selOp.innerHTML=ops.map(o=>`<option>${o}</option>`).join('');
