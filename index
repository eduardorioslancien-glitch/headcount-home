function renderReportes(){
  const activos=DATA.homeq.filter(q=>(q.status||'').trim().toUpperCase()==='ACTIVO');
  const enProceso=DATA.backlog.filter(b=>b.status&&b.status!=='ACTIVADO');
  const activados=DATA.backlog.filter(b=>b.status==='ACTIVADO');
  const meta=getMeta();
  const pct=meta>0?Math.round((activos.length/meta)*100):0;

  // KPIs ejecutivo
  document.getElementById('rk-activo').textContent=activos.length;
  document.getElementById('rk-pct').textContent=pct+'%';
  document.getElementById('rk-backlog').textContent=enProceso.length;

  // Efectividad de asistencia
  const totalReg=DATA.asistencia.length||1;
  const enRutaOk=DATA.asistencia.filter(a=>a.enRuta==='A'||a.enRuta==='T').length;
  document.getElementById('rk-efec').textContent=Math.round((enRutaOk/totalReg)*100)+'%';

  // Alertas
  const alertas=[];
  // Meta
  if(pct<80) alertas.push({icon:'🔴',title:'HC Cubierto bajo vs Meta',sub:`${activos.length} activos de ${meta} requeridos (${pct}%)`,cls:'ab-rojo'});
  else if(pct<100) alertas.push({icon:'🟡',title:'HC Cubierto cerca de Meta',sub:`${activos.length} de ${meta} (${pct}%)`,cls:'ab-amber'});
  // Backlog demorado
  const demorados=enProceso.filter(b=>parseInt(b.dilacion)||0>14);
  if(demorados.length) alertas.push({icon:'⚠️',title:`${demorados.length} candidato(s) con más de 14 días en proceso`,sub:demorados.map(b=>b.completo).join(', '),cls:'ab-amber'});
  // Faltas en asistencia
  const faltas=DATA.asistencia.filter(a=>a.enRuta==='F');
  if(faltas.length) alertas.push({icon:'🔴',title:`${faltas.length} falta(s) registrada(s)`,sub:faltas.map(a=>a.cuadrilla).join(', '),cls:'ab-rojo'});
  // Tardanzas
  const tardes=DATA.asistencia.filter(a=>a.enRuta==='T');
  if(tardes.length) alertas.push({icon:'🟡',title:`${tardes.length} tardanza(s) registrada(s)`,sub:tardes.map(a=>a.cuadrilla).join(', '),cls:'ab-amber'});
  if(!alertas.length) alertas.push({icon:'✅',title:'Sin alertas activas',sub:'Todos los indicadores en rango normal',cls:'ab-verde'});

  document.getElementById('rep-alertas').innerHTML=alertas.map(a=>`
    <div class="alerta-item">
      <div class="alerta-icon">${a.icon}</div>
      <div class="alerta-body">
        <div class="alerta-title">${a.title}</div>
        <div class="alerta-sub">${a.sub}</div>
      </div>
      <span class="alerta-badge ${a.cls}">${a.cls==='ab-rojo'?'Crítico':a.cls==='ab-amber'?'Atención':'OK'}</span>
    </div>`).join('');

  // Gráfico HC SVG
  buildRepHCChart(activos.length, meta);

  // Backlog por etapas
  const etapas=[
    {lbl:'Admitido',k:'ADMITIDO',color:'#185FA5'},
    {lbl:'Capacitado',k:'CAPACITADO',color:'#534AB7'},
    {lbl:'Certificado',k:'CERTIFICADO',color:'#BA7517'},
    {lbl:'En prueba',k:'EN PRUEBA',color:'#1D9E75'},
    {lbl:'Activado',k:'ACTIVADO',color:'#0F6E56'},
  ];
  const totalBL=DATA.backlog.length||1;
  document.getElementById('rep-backlog-etapas').innerHTML=etapas.map(e=>{
    const cnt=DATA.backlog.filter(b=>b.status===e.k).length;
    const pct2=Math.round((cnt/totalBL)*100);
    return `<div class="etapa-bar">
      <div class="etapa-lbl">${e.lbl}</div>
      <div class="etapa-track"><div class="etapa-fill" style="width:${pct2}%;background:${e.color}"></div></div>
      <div class="etapa-cnt">${cnt}</div>
    </div>`;
  }).join('');

  // Tabla asistencia operativo
  const asistMap={};
  DATA.asistencia.forEach(a=>{
    const k=a.cuadrilla;
    if(!asistMap[k]) asistMap[k]={cuadrilla:k,operador:a.operador,base:a.base,dias:0,atie:0,tard:0,falt:0};
    asistMap[k].dias++;
    if(a.enRuta==='A') asistMap[k].atie++;
    if(a.enRuta==='T') asistMap[k].tard++;
    if(a.enRuta==='F') asistMap[k].falt++;
  });
  const asistRows=Object.values(asistMap);
  document.getElementById('tbody-rep-asist').innerHTML=asistRows.length?asistRows.map(r=>{
    const pctE=r.dias>0?Math.round(((r.atie+r.tard)/r.dias)*100):0;
    const alerta=r.falt>2?'<span class="alerta-badge ab-rojo">Faltas frecuentes</span>':r.tard>2?'<span class="alerta-badge ab-amber">Tardanzas</span>':'<span class="alerta-badge ab-verde">OK</span>';
    return `<tr><td style="font-weight:500">${r.cuadrilla}</td><td>${r.operador}</td><td>${r.base}</td><td style="text-align:center">${r.dias}</td><td style="text-align:center;color:var(--verde)">${r.atie}</td><td style="text-align:center;color:var(--amber)">${r.tard}</td><td style="text-align:center;color:var(--rojo)">${r.falt}</td><td style="text-align:center;font-weight:600">${pctE}%</td><td>${alerta}</td></tr>`;
  }).join(''):`<tr><td colspan="9" class="empty">Sin registros de asistencia</td></tr>`;

  // Tabla backlog operativo
