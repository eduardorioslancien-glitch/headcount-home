const CODIGOS=['A','T','F','D',''];
function sigCodigo(c){ return CODIGOS[(CODIGOS.indexOf(c)+1)%CODIGOS.length] }
function acClass(c){ return c==='A'?'aA':c==='T'?'aT':c==='F'?'aF':c==='D'?'aD':'a_' }

function renderAsistencia(){
  const activos=DATA.homeq.filter(q=>{
    const s=(q.status||'').toString().trim().toUpperCase();
    return s==='ACTIVO';
  });
  if(!activos.length){
    document.getElementById('tbody-asist').innerHTML=`<tr><td colspan="7" class="empty">Sin cuadrillas activas para esta fecha</td></tr>`;
    window._asistFilas=[];
    return;
  }
  const filas=activos.map(q=>{
    const reg=DATA.asistencia.find(a=>(a.cuadrilla||'').trim()===(q.completo||'').trim())||{};
    return Object.assign({},q,{prog:reg.prog||'',confirma:reg.confirma||'',charla:reg.charla||'',enRuta:reg.enRuta||''});
  });
  window._asistFilas=filas;
  document.getElementById('tbody-asist').innerHTML=filas.map((f,i)=>
    `<tr><td style="font-weight:500">${f.completo}</td><td>${f.operador}</td><td>${f.base}</td>
    <td style="text-align:center"><span class="ac ${acClass(f.prog)}" onclick="toggleAc(${i},'prog')">${f.prog||'—'}</span></td>
    <td style="text-align:center"><span class="ac ${acClass(f.confirma)}" onclick="toggleAc(${i},'confirma')">${f.confirma||'—'}</span></td>
    <td style="text-align:center"><span class="ac ${acClass(f.charla)}" onclick="toggleAc(${i},'charla')">${f.charla||'—'}</span></td>
    <td style="text-align:center"><span class="ac ${acClass(f.enRuta)}" onclick="toggleAc(${i},'enRuta')">${f.enRuta||'—'}</span></td></tr>`
  ).join('');
  // Reporte 30 días
  document.getElementById('tbody-rep30').innerHTML=activos.map(q=>{
    const regs=DATA.asistencia.filter(a=>a.cuadrilla===q.completo);
    return `<tr><td>${q.completo}</td><td>${regs.length}</td><td>${regs.filter(a=>a.enRuta==='A').length}</td><td>${regs.filter(a=>a.enRuta==='T').length}</td><td>${regs.filter(a=>a.enRuta==='F').length}</td><td>${regs.filter(a=>a.enRuta==='D').length}</td></tr>`;
  }).join('');
}

function toggleAc(idx,campo){
  const f=window._asistFilas; if(!f||!f[idx]) return;
  f[idx][campo]=sigCodigo(f[idx][campo]);
  // Solo actualizar la celda específica sin re-renderizar todo
  const codigos=['A','T','F','D',''];
  const val=f[idx][campo];
  const clsMap={'A':'aA','T':'aT','F':'aF','D':'aD','':'a_'};
  const colMap={'prog':3,'confirma':4,'charla':5,'enRuta':6};
  const col=colMap[campo];
  if(!col) return;
  const tbody=document.getElementById('tbody-asist');
  const row=tbody.querySelectorAll('tr')[idx];
  if(!row) return;
  const cell=row.querySelectorAll('td')[col];
  if(!cell) return;
  const span=cell.querySelector('.ac');
  if(!span) return;
  span.className='ac '+clsMap[val];
  span.textContent=val||'—';
}

async function guardarAsistencia(){
  const f=window._asistFilas, fecha=document.getElementById('asist-fecha').value;
