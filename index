}

function generarPlantillaAsistencia(){
  const fechaIni = document.getElementById('ap-fecha-ini').value;
  const fechaFin = document.getElementById('ap-fecha-fin').value || fechaIni;
  const op = document.getElementById('ap-op').value;
  const inclProg    = document.getElementById('ap-prog').checked;
  const inclConfirma= document.getElementById('ap-confirma').checked;
  const inclCharla  = document.getElementById('ap-charla').checked;
  const inclEnRuta  = document.getElementById('ap-enruta').checked;

  if(!fechaIni){ showToast('⚠ Selecciona al menos una fecha'); return; }

  // Get active cuadrillas
  let activos = DATA.homeq.filter(q => q.status==='ACTIVO');
  if(op) activos = activos.filter(q => q.operador === op);
  if(!activos.length){ showToast('⚠ No hay cuadrillas activas'); return; }

  // Build date range
  const fechas = [];
  let cur = new Date(fechaIni + 'T00:00:00');
  const fin = new Date(fechaFin + 'T00:00:00');
  while(cur <= fin){
    fechas.push(cur.toISOString().split('T')[0]);
    cur.setDate(cur.getDate() + 1);
  }

  // Build headers
  const headers = ['FECHA','CUADRILLA','OPERADOR','BASE'];
  if(inclProg)     headers.push('PROG');
  if(inclConfirma) headers.push('CONFIRMA');
  if(inclCharla)   headers.push('CHARLA');
  if(inclEnRuta)   headers.push('EN RUTA');

  // Build rows — one per cuadrilla per date
  const rows = [headers];
  fechas.forEach(fecha => {
    activos.forEach(q => {
      const row = [fecha, q.completo, q.operador, q.base];
      if(inclProg)     row.push('');
      if(inclConfirma) row.push('');
      if(inclCharla)   row.push('');
      if(inclEnRuta)   row.push('');
      rows.push(row);
    });
  });

  // Add legend row at the top after headers
  const leyenda = ['LEYENDA: A=Asiste  T=Tardanza  F=Falta  D=Descanso','','',''];
  if(inclProg)     leyenda.push('');
  if(inclConfirma) leyenda.push('');
  if(inclCharla)   leyenda.push('');
  if(inclEnRuta)   leyenda.push('');
  rows.splice(1, 0, leyenda);

  // Generate CSV
  var csv = toCSV(rows);
  const nombreArchivo = `Asistencia_${op||'TODAS'}_${fechaIni}${fechaFin!==fechaIni?'_al_'+fechaFin:''}.csv`;
  const blob = new Blob(['﻿'+csv], {type:'text/csv;charset=utf-8'});
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url; a.download = nombreArchivo;
  a.click(); URL.revokeObjectURL(url);

  cerrarModal('modal-asist-plantilla');
  showToast(`✅ Plantilla descargada — ${rows.length-2} filas`);
}

