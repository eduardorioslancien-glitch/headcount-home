async function sheetRead(range){
  const url=`${BASE_URL}/${encodeURIComponent(range)}?key=${API_KEY}`;
  const res=await fetch(url);
  if(!res.ok) throw new Error(`Error ${res.status} leyendo ${range}`);
  const d=await res.json();
  return d.values||[];
}

// ============================================================
// WEBAPP — escribir
// ============================================================
async function wPost(body){
  // Apps Script requiere enviar como form-encoded para evitar CORS preflight
  const params = new URLSearchParams();
  params.append('data', JSON.stringify(body));
  const res = await fetch(WEBAPP_URL, {
    method: 'POST',
    body: params
  });
  return res.json();
}

