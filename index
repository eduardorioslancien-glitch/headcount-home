  document.getElementById('bl-cnt-adm').textContent=DATA.backlog.filter(b=>b.status==='ADMITIDO').length;
  document.getElementById('bl-cnt-cap').textContent=DATA.backlog.filter(b=>b.status==='CAPACITADO').length;
  document.getElementById('bl-cnt-cert').textContent=DATA.backlog.filter(b=>b.status==='CERTIFICADO').length;
  document.getElementById('bl-cnt-pru').textContent=DATA.backlog.filter(b=>b.status==='EN PRUEBA').length;
