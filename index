function actualizarHito(numDoc){
  const b=DATA.backlog.find(x=>x.numDoc===numDoc); if(!b) return;
  const HITOS=[['fAdmision','Admisión'],['fCapac','Capacitación'],['fCert','Certificación'],['fPrueba','Prueba campo'],['fActiv','Activación']];
  const body=HITOS.map(([k,lbl])=>`
    <div style="display:flex;align-items:center;gap:10px;padding:8px 0;border-bottom:1px solid var(--gris1)">
      <div style="width:130px;font-size:11px;font-weight:600">${lbl}</div>
      <input type="date" id="hi-${k}" value="${b[k]||''}" style="font-size:11px;padding:5px 8px;border:1px solid var(--gris2);border-radius:var(--radius);font-family:var(--font)">
      <span style="font-size:10px;color:var(--gris3)">${b[k]?'✅ Registrado':'Pendiente'}</span>
    </div>`).join('');
  document.getElementById('modal-cuad-title').textContent='Actualizar hitos — '+b.completo;
  document.getElementById('modal-cuad-body').innerHTML=`
    <p style="font-size:11px;color:var(--gris3);margin-bottom:12px">Ingresa las fechas de cada hito completado. Al registrar Activación el técnico pasará a Activo en Cuadrillas.</p>
    ${body}
    <div style="display:flex;justify-content:flex-end;gap:8px;margin-top:14px">
      <button class="btn" onclick="cerrarModal('modal-cuad')">Cancelar</button>
      <button class="btn btn-primary" onclick="guardarHitos('${numDoc}')">Guardar hitos</button>
    </div>`;
  abrirModal('modal-cuad');
}

async function guardarHitos(numDoc){
  const HITOS=['fAdmision','fCapac','fCert','fPrueba','fActiv'];
  const vals=HITOS.map(k=>document.getElementById('hi-'+k)?.value||'');
  showToast('Guardando hitos...');
  try {
    // Buscar fila en BACKLOG y actualizar
    const res=await wPost({accion:'actualizar_hitos',contrata:CONTRATA,hoja:'BACKLOG',numDoc,hitos:{
      fAdmision:vals[0],fCapac:vals[1],fCert:vals[2],fPrueba:vals[3],fActiv:vals[4]
    }});
    if(res&&res.ok){
      showToast('✅ Hitos actualizados');
      cerrarModal('modal-cuad');
      await Promise.all([cargarBACKLOG(),cargarHOMEQ(),cargarAsistencia()]);
      renderBacklog(); renderCuadrillas(); renderDashboard();
    } else showToast('⚠ Error: '+(res?.error||''));
  } catch(e){ showToast('⚠ Error: '+e.message); }
}

