          </div>
          <button class="btn btn-sm" onclick="actualizarHito('${b.numDoc}')">Actualizar hito</button>
        </div>
        <div class="htl">${HITOS.map(([k,lbl],i)=>{ const done=!!b[k]; return `<div class="hito ${done?'done':'pend'}"><div class="hdot">${done?'✓':i+1}</div><div class="hn">${lbl}</div><div class="hd">${b[k]?fmtDate(b[k]):'—'}</div></div>`; }).join('')}</div>
      </div>`;
    }).join('');
  }

  // Historial activados
  document.getElementById('tbody-bl-hist').innerHTML=activados.length?activados.map(b=>`<tr>
    <td style="font-weight:500">${b.completo}</td>
    <td style="font-family:var(--mono);font-size:10px">${b.numDoc}</td>
    <td>${b.operador||'—'}</td><td>${b.base||'—'}</td>
