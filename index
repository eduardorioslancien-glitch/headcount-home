function calcActualizarFiltros(){
  const op=document.getElementById('calc-op').value;
  const contratas=[...new Set(PRECIARIO_DATA.filter(p=>p.op===op).map(p=>p.contrata))];
  document.getElementById('calc-contrata').innerHTML=contratas.map(c=>`<option>${c}</option>`).join('');
  calcActualizarItems();
}

function calcActualizarItems(){
  const op=document.getElementById('calc-op').value;
  const contrata=document.getElementById('calc-contrata').value;
  const filtered=PRECIARIO_DATA.filter(p=>p.op===op&&p.contrata===contrata);
  const tipos=[...new Set(filtered.map(p=>p.tipo))];
  document.getElementById('calc-tipop').innerHTML=tipos.map(t=>`<option>${t}</option>`).join('');
  const servs=[...new Set(filtered.map(p=>p.servicio))];
  document.getElementById('calc-serv-tipo').innerHTML=servs.map(s=>`<option>${s}</option>`).join('');
  calcActualizarItemsSelect();
}

function calcActualizarItemsSelect(){
  const op=document.getElementById('calc-op').value;
  const contrata=document.getElementById('calc-contrata').value;
  const tipo=document.getElementById('calc-tipop').value;
  const servTipo=document.getElementById('calc-serv-tipo').value;
  const items=PRECIARIO_DATA.filter(p=>p.op===op&&p.contrata===contrata&&p.tipo===tipo&&p.servicio===servTipo);
  document.getElementById('calc-item').innerHTML=items.map(p=>`<option value="${p.soles}">${p.item} — S/. ${p.soles.toFixed(2)}</option>`).join('');
  calcular();
}

function calcular(){
  const dias=parseInt(document.getElementById('calc-dias')?.value)||0;
  const cant=parseInt(document.getElementById('calc-cant')?.value)||0;
  const itemSel=document.getElementById('calc-item');
  if(!itemSel||!itemSel.options.length){ document.getElementById('calc-total').textContent='S/. 0.00'; return; }
  const tarifa=parseFloat(itemSel.value)||0;
  const itemNom=itemSel.options[itemSel.selectedIndex]?.text||'';
  const totalServicios=tarifa*cant*dias;

  // Bonos de asistencia
  const op=document.getElementById('calc-op').value;
  const contrata=document.getElementById('calc-contrata').value;
  const bonosMatch=BONOS_DATA.filter(b=>b.op===op&&b.contrata===contrata);
  let bonoTotal=0, bonoDetalle='';
  bonosMatch.forEach(b=>{
    // Bono por día puntual
    const bonoDia=b.valorDia*dias;
    // Bono escala por días
    let bonoEscala=0;
    if(b.escalas){
      const escMatch=[...b.escalas].reverse().find(e=>dias>=e.dias);
      if(escMatch) bonoEscala=escMatch.bono;
    }
    bonoTotal+=bonoDia+bonoEscala;
    bonoDetalle+=`<div style="margin-top:4px"><strong>${b.tipo}:</strong> S/. ${bonoDia.toFixed(2)} por puntualidad diaria`;
    if(b.escalas){ bonoDetalle+=` + <strong>S/. ${bonoEscala.toFixed(2)}</strong> bono por ${dias} días`; }
    bonoDetalle+='</div>';
  });

  const totalFinal=totalServicios+bonoTotal;
  document.getElementById('calc-total').textContent='S/. '+totalFinal.toFixed(2);
  document.getElementById('calc-sub').textContent=`${dias} días × ${cant} servicios/día`;
  document.getElementById('calc-desglose-content').innerHTML=`
    <div style="margin-bottom:6px;font-weight:600;color:var(--negro)">Desglose:</div>
    <div>📋 <strong>${itemNom.split('—')[0].trim()}</strong></div>
    <div style="margin-top:4px">Tarifa unitaria: <strong>S/. ${tarifa.toFixed(2)}</strong></div>
    <div>Servicios totales: <strong>${cant*dias}</strong> (${cant}/día × ${dias} días)</div>
    <div>Subtotal servicios: <strong>S/. ${totalServicios.toFixed(2)}</strong></div>
    ${bonoDetalle?`<div style="margin-top:8px;padding-top:6px;border-top:1px solid var(--gris2);color:var(--verde)">🎯 Bonos:</div>${bonoDetalle}`:''}
    <div style="margin-top:8px;padding-top:6px;border-top:1px solid var(--gris2);font-size:13px;font-weight:700;color:var(--verde)">TOTAL ESTIMADO: S/. ${totalFinal.toFixed(2)}</div>
  `;
}

