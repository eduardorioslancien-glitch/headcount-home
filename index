  const fechaFin = document.getElementById('ap-fecha-fin').value;
  let info = `Plantilla para ${activos.length} cuadrillas`;
  if(fechaFin && fechaFin !== fechaIni){
    const dias = Math.round((new Date(fechaFin) - new Date(fechaIni)) / 86400000) + 1;
    info += ` × ${dias} días = ${activos.length * dias} filas`;
  }
